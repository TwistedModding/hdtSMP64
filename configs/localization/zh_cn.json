{
  "Simplification": "\u7b80\u5316",
  "Performance": "\u6027\u80fd",
  "Wind": "\u98ce",
  "Validation": "\u9a8c\u8bc1",
  "Logs": "\u65e5\u5fd7",
  "Commands": "\u547d\u4ee4",
  "Presets": "\u9884\u8bbe",
  "Disabling some physics": "\u7981\u7528\u90e8\u5206\u7269\u7406",
  "Disable hair physics when there's a wig": "\u6234\u5047\u53d1\u65f6\u7981\u7528\u5934\u53d1\u7269\u7406",
  "Skip hair physics when an armor occupies the hair/longhair slot (a wig on top of the hair).": "\u5f53\u62a4\u7532\u5360\u7528\u5934\u53d1/\u957f\u53d1\u69fd\u4f4d\u65f6\uff08\u5934\u53d1\u4e0a\u7684\u5047\u53d1\uff09\uff0c\u8df3\u8fc7\u5934\u53d1\u7269\u7406\u3002",
  "No physics for your character in 1st person view": "\u7b2c\u4e00\u4eba\u79f0\u89c6\u89d2\u4e0b\u4e0d\u5bf9\u4f60\u7684\u89d2\u8272\u4f7f\u7528\u7269\u7406",
  "Skip the player's physics while in first-person view to save performance.": "\u5728\u7b2c\u4e00\u4eba\u79f0\u89c6\u89d2\u4e0b\u8df3\u8fc7\u73a9\u5bb6\u7684\u7269\u7406\u8fd0\u7b97\u4ee5\u8282\u7701\u6027\u80fd\u3002",
  "Enable NPC face parts physics": "\u542f\u7528 NPC \u9762\u90e8\u90e8\u4ef6\u7269\u7406",
  "Calculate physics for NPC face parts.": "\u8ba1\u7b97 NPC \u9762\u90e8\u90e8\u4ef6\u7684\u7269\u7406\u3002",
  "Distance / screen-size culling": "\u6309\u8ddd\u79bb/\u5c4f\u5e55\u5c3a\u5bf8\u5254\u9664",
  "Always-on distance": "\u59cb\u7ec8\u542f\u7528\u7684\u8ddd\u79bb",
  "Physics is always calculated for NPCs closer than this (units), even off-screen.": "\u5bf9\u4e8e\u6bd4\u6b64\u8ddd\u79bb\uff08\u5355\u4f4d\uff09\u66f4\u8fd1\u7684 NPC\uff0c\u5373\u4f7f\u5728\u5c4f\u5e55\u5916\u4e5f\u59cb\u7ec8\u8ba1\u7b97\u7269\u7406\u3002",
  "Min screen size %": "\u6700\u5c0f\u5c4f\u5e55\u5c3a\u5bf8 %",
  "Skip non-player NPCs smaller than this % of screen height. 0 disables the check.": "\u8df3\u8fc7\u5c0f\u4e8e\u5c4f\u5e55\u9ad8\u5ea6\u6b64\u767e\u5206\u6bd4\u7684\u975e\u73a9\u5bb6 NPC\u30020 \u8868\u793a\u7981\u7528\u68c0\u67e5\u3002",
  "Skip dead actors": "\u8df3\u8fc7\u6b7b\u4ea1\u89d2\u8272",
  "Skip physics for dead non-player actors (corpses). The player is never affected.": "\u8df3\u8fc7\u6b7b\u4ea1\u7684\u975e\u73a9\u5bb6\u89d2\u8272\uff08\u5c38\u4f53\uff09\u7684\u7269\u7406\u3002\u73a9\u5bb6\u6c38\u8fdc\u4e0d\u53d7\u5f71\u54cd\u3002",
  "Limiting active physics NPCs": "\u9650\u5236\u6d3b\u52a8\u7684\u7269\u7406 NPC",
  "Maximum physics NPCs": "\u7269\u7406 NPC \u6700\u5927\u6570\u91cf",
  "Upper bound on simultaneously simulated NPCs (including the player).": "\u540c\u65f6\u6a21\u62df\u7684 NPC \u6570\u91cf\u4e0a\u9650\uff08\u5305\u62ec\u73a9\u5bb6\uff09\u3002",
  "Auto-adjust the max number of physics NPCs": "\u81ea\u52a8\u8c03\u6574\u7269\u7406 NPC \u7684\u6700\u5927\u6570\u91cf",
  "Dynamically reduce active NPCs to stay within the frame-time budget below.": "\u52a8\u6001\u51cf\u5c11\u6d3b\u52a8 NPC\uff0c\u4ee5\u4fdd\u6301\u5728\u4e0b\u9762\u7684\u5e27\u65f6\u95f4\u9884\u7b97\u5185\u3002",
  "Frame-time budget (ms)": "\u5e27\u65f6\u95f4\u9884\u7b97 (ms)",
  "How many ms/frame physics may spend before it starts dropping active NPCs.": "\u7269\u7406\u5728\u5f00\u59cb\u51cf\u5c11\u6d3b\u52a8 NPC \u4e4b\u524d\u6bcf\u5e27\u53ef\u82b1\u8d39\u7684\u6beb\u79d2\u6570\u3002",
  "Adjustment speed (sample size)": "\u8c03\u6574\u901f\u5ea6\uff08\u91c7\u6837\u6570\uff09",
  "How many samples to average for the auto-adjuster. Higher = smoother but slower to react.": "\u81ea\u52a8\u8c03\u6574\u65f6\u5e73\u5747\u7684\u91c7\u6837\u6570\u3002\u8d8a\u9ad8\u8d8a\u5e73\u6ed1\uff0c\u4f46\u53cd\u5e94\u8d8a\u6162\u3002",
  "Simulation quality": "\u6a21\u62df\u8d28\u91cf",
  "Solver iterations": "\u6c42\u89e3\u5668\u8fed\u4ee3\u6b21\u6570",
  "The physics engine's solver iterations. Higher = more accurate, more CPU.": "\u7269\u7406\u5f15\u64ce\u7684\u6c42\u89e3\u5668\u8fed\u4ee3\u6b21\u6570\u3002\u8d8a\u9ad8\u8d8a\u7cbe\u786e\uff0c\u4f46 CPU \u5360\u7528\u8d8a\u591a\u3002",
  "ERP": "ERP",
  "Error-reduction force pulling constraints back into place each step.": "\u6bcf\u6b65\u5c06\u7ea6\u675f\u62c9\u56de\u539f\u4f4d\u7684\u8bef\u5dee\u4fee\u6b63\u529b\u3002",
  "Simulation frequency": "\u6a21\u62df\u9891\u7387",
  "Use real time": "\u4f7f\u7528\u771f\u5b9e\u65f6\u95f4",
  "Drive physics from the real-world clock instead of the in-game clock (better under slow-time).": "\u4f7f\u7528\u73b0\u5b9e\u4e16\u754c\u65f6\u949f\u800c\u975e\u6e38\u620f\u5185\u65f6\u949f\u9a71\u52a8\u7269\u7406\uff08\u5728\u6162\u52a8\u4f5c\u4e0b\u66f4\u597d\uff09\u3002",
  "Simulation frequency (min-fps)": "\u6a21\u62df\u9891\u7387 (min-fps)",
  "Physics steps per second. Never set below 60 or the physics engine misbehaves. Higher = smoother, more CPU.": "\u6bcf\u79d2\u7269\u7406\u6b65\u6570\u3002\u5207\u52ff\u8bbe\u7f6e\u4f4e\u4e8e 60\uff0c\u5426\u5219\u7269\u7406\u5f15\u64ce\u4f1a\u51fa\u9519\u3002\u8d8a\u9ad8\u8d8a\u5e73\u6ed1\uff0c\u4f46 CPU \u5360\u7528\u8d8a\u591a\u3002",
  "Max sub-steps": "\u6700\u5927\u5b50\u6b65\u6570",
  "Max physics steps per frame. Slowdowns occur below (min-fps / maxSubSteps) fps.": "\u6bcf\u5e27\u6700\u5927\u7269\u7406\u6b65\u6570\u3002\u4f4e\u4e8e (min-fps / maxSubSteps) fps \u65f6\u4f1a\u51fa\u73b0\u51cf\u901f\u3002",
  "Rotation limits": "\u65cb\u8f6c\u9650\u5236",
  "Limit rotation speed": "\u9650\u5236\u65cb\u8f6c\u901f\u5ea6",
  "Rotate the player slowly through large turns instead of instantly (prevents physics explosions).": "\u5728\u5927\u5e45\u8f6c\u8eab\u65f6\u8ba9\u73a9\u5bb6\u7f13\u6162\u65cb\u8f6c\u800c\u975e\u77ac\u95f4\u65cb\u8f6c\uff08\u9632\u6b62\u7269\u7406\u7206\u70b8\uff09\u3002",
  "Rotation speed limit (rad/s)": "\u65cb\u8f6c\u901f\u5ea6\u4e0a\u9650 (rad/s)",
  "Maximum rotation speed in radians per second when limiting is on.": "\u542f\u7528\u9650\u5236\u65f6\u6bcf\u79d2\u5f27\u5ea6\u7684\u6700\u5927\u65cb\u8f6c\u901f\u5ea6\u3002",
  "Reset physics on big unlimited turns": "\u5728\u5927\u5e45\u65e0\u9650\u5236\u8f6c\u8eab\u65f6\u91cd\u7f6e\u7269\u7406",
  "When rotation isn't limited, reset physics on a large turn instead of simulating the whole sweep.": "\u5f53\u65cb\u8f6c\u4e0d\u53d7\u9650\u5236\u65f6\uff0c\u5728\u5927\u5e45\u8f6c\u8eab\u65f6\u91cd\u7f6e\u7269\u7406\uff0c\u800c\u4e0d\u662f\u6a21\u62df\u6574\u4e2a\u8fc7\u7a0b\u3002",
  "Reset angle (degrees)": "\u91cd\u7f6e\u89d2\u5ea6\uff08\u5ea6\uff09",
  "Turn angle (degrees) above which the reset is triggered.": "\u89e6\u53d1\u91cd\u7f6e\u7684\u8f6c\u8eab\u89d2\u5ea6\uff08\u5ea6\uff09\u3002",
  "Enable FSMP-native wind": "\u542f\u7528 FSMP \u539f\u751f\u98ce",
  "Apply FSMP's own wind force to physics objects.": "\u5c06 FSMP \u81ea\u5e26\u7684\u98ce\u529b\u5e94\u7528\u4e8e\u7269\u7406\u5bf9\u8c61\u3002",
  "Wind strength": "\u98ce\u529b\u5f3a\u5ea6",
  "Base wind strength. For reference, gravity is 9.8.": "\u57fa\u7840\u98ce\u529b\u5f3a\u5ea6\u3002\u4f5c\u4e3a\u53c2\u8003\uff0c\u91cd\u529b\u4e3a 9.8\u3002",
  "Distance for no wind": "\u65e0\u98ce\u8ddd\u79bb",
  "How close to an obstruction for wind to be fully blocked.": "\u8ddd\u79bb\u969c\u788d\u7269\u591a\u8fd1\u65f6\u98ce\u88ab\u5b8c\u5168\u963b\u6321\u3002",
  "Distance for max wind": "\u6700\u5927\u98ce\u8ddd\u79bb",
  "How far from an obstruction for wind to be unblocked. Scales linearly with the above.": "\u8ddd\u79bb\u969c\u788d\u7269\u591a\u8fdc\u65f6\u98ce\u4e0d\u518d\u88ab\u963b\u6321\u3002\u4e0e\u4e0a\u8ff0\u503c\u7ebf\u6027\u7f29\u653e\u3002",
  "Mods folder": "Mod \u6587\u4ef6\u5939",
  "Your mod manager's mods folder (MO2 mods/ or Vortex staging). When set, 'smp report' scans it\nnatively instead of through the virtual file system, which is much faster on big load orders.\nLeave empty to scan data/ through the VFS.": "\u4f60\u7684 Mod \u7ba1\u7406\u5668\u7684 mods \u6587\u4ef6\u5939\uff08MO2 \u7684 mods/ \u6216 Vortex \u7684\u6682\u5b58\u76ee\u5f55\uff09\u3002\u8bbe\u7f6e\u540e\uff0c'smp report' \u5c06\n\u76f4\u63a5\u626b\u63cf\u5b83\uff0c\u800c\u4e0d\u662f\u901a\u8fc7\u865a\u62df\u6587\u4ef6\u7cfb\u7edf\uff0c\u8fd9\u5728\u5927\u578b\u52a0\u8f7d\u987a\u5e8f\u4e0b\u5feb\u5f97\u591a\u3002\n\u7559\u7a7a\u5219\u901a\u8fc7 VFS \u626b\u63cf data/\u3002",
  "Log level": "\u65e5\u5fd7\u7ea7\u522b",
  "0 = Fatal, 1 = Error, 2 = Warning, 3 = Message, 4 = Verbose, 5 = Debug.": "0 = \u81f4\u547d, 1 = \u9519\u8bef, 2 = \u8b66\u544a, 3 = \u6d88\u606f, 4 = \u8be6\u7ec6, 5 = \u8c03\u8bd5\u3002",
  "Master switch": "\u603b\u5f00\u5173",
  "SMP enabled": "SMP \u5df2\u542f\u7528",
  "Turn the whole physics simulation on or off (same as 'smp on' / 'smp off').": "\u6253\u5f00\u6216\u5173\u95ed\u6574\u4e2a\u7269\u7406\u6a21\u62df\uff08\u7b49\u540c\u4e8e 'smp on' / 'smp off'\uff09\u3002",
  "Console commands (shown below, and in the console / log)": "\u63a7\u5236\u53f0\u547d\u4ee4\uff08\u663e\u793a\u5728\u4e0b\u65b9\uff0c\u4ee5\u53ca\u63a7\u5236\u53f0 / \u65e5\u5fd7\u4e2d\uff09",
  "smp (basic info)": "smp\uff08\u57fa\u672c\u4fe1\u606f\uff09",
  "smp reset": "smp reset",
  "Reload config and reset all physics systems.": "\u91cd\u65b0\u52a0\u8f7d\u914d\u7f6e\u5e76\u91cd\u7f6e\u6240\u6709\u7269\u7406\u7cfb\u7edf\u3002",
  "smp list": "smp list",
  "smp detail": "smp detail",
  "smp dumptree (player)": "smp dumptree\uff08\u73a9\u5bb6\uff09",
  "Dump the player's 3D node tree to the log (needs log level 3+).": "\u5c06\u73a9\u5bb6\u7684 3D \u8282\u70b9\u6811\u8f93\u51fa\u5230\u65e5\u5fd7\uff08\u9700\u8981\u65e5\u5fd7\u7ea7\u522b 3+\uff09\u3002",
  "smp QueryOverride": "smp QueryOverride",
  "Validator": "\u9a8c\u8bc1\u5668",
  "smp report": "smp report",
  "Run the physics-asset validator in the background; writes a report file.": "\u5728\u540e\u53f0\u8fd0\u884c\u7269\u7406\u8d44\u6e90\u9a8c\u8bc1\u5668\uff1b\u5199\u5165\u4e00\u4e2a\u62a5\u544a\u6587\u4ef6\u3002",
  "smp report gear": "smp report gear",
  "Validate currently equipped gear only.": "\u4ec5\u9a8c\u8bc1\u5f53\u524d\u88c5\u5907\u7684\u7269\u54c1\u3002",
  "Refresh": "\u5237\u65b0",
  "(%d found)": "(\u627e\u5230 %d \u4e2a)",
  "No presets found in configsPresets/. Drop *.json preset files there.": "\u5728 configsPresets/ \u4e2d\u672a\u627e\u5230\u9884\u8bbe\u3002\u8bf7\u5c06 *.json \u9884\u8bbe\u6587\u4ef6\u653e\u5728\u90a3\u91cc\u3002",
  "(loaded)": "(\u5df2\u52a0\u8f7d)",
  "Auto (game language)": "\u81ea\u52a8\uff08\u6e38\u620f\u8bed\u8a00\uff09",
  "Search settings": "\u641c\u7d22\u8bbe\u7f6e",
  "Reset this setting to its default": "\u5c06\u6b64\u8bbe\u7f6e\u91cd\u7f6e\u4e3a\u9ed8\u8ba4\u503c",
  "Physics is ON": "\u7269\u7406\u5df2\u5f00\u542f",
  "Physics is OFF": "\u7269\u7406\u5df2\u5173\u95ed",
  "Distance for no wind should be below distance for max wind.": "\u65e0\u98ce\u8ddd\u79bb\u5e94\u5c0f\u4e8e\u6700\u5927\u98ce\u8ddd\u79bb\u3002",
  "The menu language. 'Auto' follows Skyrim's own language.": "\u83dc\u5355\u8bed\u8a00\u3002\u201c\u81ea\u52a8\u201d\u8ddf\u968f Skyrim \u7684\u8bed\u8a00\u3002",
  "In-game configuration menu for Faster HDT-SMP.": "Faster HDT-SMP \u7684\u6e38\u620f\u5185\u914d\u7f6e\u83dc\u5355\u3002",
  "Documentation": "\u6587\u6863",
  "Nexus page": "Nexus \u9875\u9762",
  "Report a bug": "\u62a5\u544a\u9519\u8bef",
  "Open in your browser": "\u5728\u6d4f\u89c8\u5668\u4e2d\u6253\u5f00",
  "Configuration": "\u914d\u7f6e",
  "Output": "\u8f93\u51fa",
  "Clear": "\u6e05\u9664",
  "Browse for your mods folder": "\u6d4f\u89c8\u4f60\u7684 mods \u6587\u4ef6\u5939",
  "Live physics performance data --- the same numbers written to hdtSMP64.log.": "\u5b9e\u65f6\u7269\u7406\u6027\u80fd\u6570\u636e \u2014\u2014 \u4e0e hdtSMP64.log \u4e2d\u8bb0\u5f55\u7684\u6570\u503c\u76f8\u540c\u3002",
  "Physics simulation is off.": "\u7269\u7406\u6a21\u62df\u5df2\u5173\u95ed\u3002",
  "Frame-time cost": "\u6bcf\u5e27\u8017\u65f6",
  "Frame-time impact": "\u6bcf\u5e27\u5f71\u54cd",
  "Setup": "\u51c6\u5907",
  "Wait": "\u7b49\u5f85",
  "Apply": "\u5e94\u7528",
  "Background calc": "\u540e\u53f0\u8ba1\u7b97",
  "Hidden (overlapped)": "\u9690\u85cf\uff08\u91cd\u53e0\uff09",
  "Total CPU work": "CPU \u603b\u5de5\u4f5c\u91cf",
  "Load": "\u8d1f\u8f7d",
  "Active physics NPCs": "\u542f\u7528\u7269\u7406\u7684 NPC",
  "Show overlay while playing": "\u6e38\u620f\u65f6\u663e\u793a\u53e0\u52a0\u7a97\u53e3",
  "Show a small always-on-top readout of the frame-time cost while you play.": "\u6e38\u620f\u65f6\u663e\u793a\u4e00\u4e2a\u59cb\u7ec8\u7f6e\u9876\u7684\u6bcf\u5e27\u8017\u65f6\u5c0f\u7a97\u3002",
  "Gear only": "\u4ec5\u88c5\u5907",
  "Include warnings": "\u5305\u542b\u8b66\u544a",
  "Include warnings and info in the report (otherwise errors only).": "\u5728\u62a5\u544a\u4e2d\u5305\u542b\u8b66\u544a\u548c\u4fe1\u606f\uff08\u5426\u5219\u4ec5\u9519\u8bef\uff09\u3002",
  "Run report": "\u8fd0\u884c\u62a5\u544a",
  "Profiler": "\u6027\u80fd\u5206\u6790\u5668",
  "Sample frames": "\u91c7\u6837\u5e27\u6570",
  "Print every N frames": "\u6bcf N \u5e27\u8f93\u51fa\u4e00\u6b21",
  "Toggle physics profiler": "\u5207\u6362\u7269\u7406\u6027\u80fd\u5206\u6790\u5668",
  "Toggle physics profiler capture on/off; results are written to hdtSMP64.log.": "\u5f00\u5173\u7269\u7406\u6027\u80fd\u5206\u6790\u5668\u7684\u6355\u83b7\uff1b\u7ed3\u679c\u5199\u5165 hdtSMP64.log\u3002",
  "Log file": "\u65e5\u5fd7\u6587\u4ef6",
  "Auto-refresh": "\u81ea\u52a8\u5237\u65b0",
  "(last %d KB)": "(\u6700\u540e %d KB)",
  "Increase font size": "\u589e\u5927\u5b57\u4f53",
  "Decrease font size": "\u51cf\u5c0f\u5b57\u4f53",
  "Measures": "\u6d4b\u91cf",
  "Home": "\u4e3b\u9875",
  "The page names on the left switch language after a game restart.": "\u5de6\u4fa7\u7684\u9875\u9762\u540d\u79f0\u5c06\u5728\u6e38\u620f\u91cd\u542f\u540e\u5207\u6362\u8bed\u8a00\u3002",
  "Bundle a bug report": "\u6253\u5305\u9519\u8bef\u62a5\u544a",
  "Current hdtSMP64.log": "\u5f53\u524d\u7684 hdtSMP64.log",
  "Last validation report": "\u6700\u65b0\u7684\u9a8c\u8bc1\u62a5\u544a",
  "Adds a fresh 'smp report gear' report to the zip. This takes a few seconds.": "\u5411 zip \u4e2d\u6dfb\u52a0\u4e00\u4efd\u65b0\u7684 'smp report gear' \u62a5\u544a\u3002\u8fd9\u9700\u8981\u51e0\u79d2\u949f\u3002",
  "Last crash log": "\u6700\u65b0\u7684\u5d29\u6e83\u65e5\u5fd7",
  "Adds the most recent CrashLogger crash log, if any.": "\u6dfb\u52a0\u6700\u65b0\u7684 CrashLogger \u5d29\u6e83\u65e5\u5fd7\uff08\u5982\u679c\u6709\uff09\u3002",
  "Build report zip": "\u521b\u5efa zip",
  "Open logs folder": "\u6253\u5f00\u65e5\u5fd7\u6587\u4ef6\u5939",
  "Building the report zip...": "\u6b63\u5728\u521b\u5efa zip...",
  "Report zip saved:": "\u5df2\u4fdd\u5b58 zip\uff1a",
  "Could not build the report zip.": "\u65e0\u6cd5\u521b\u5efa zip\u3002"
}
