{
  "Simplification": "\u0423\u043f\u0440\u043e\u0449\u0435\u043d\u0438\u0435",
  "Performance": "\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c",
  "Wind": "\u0412\u0435\u0442\u0435\u0440",
  "Validation": "\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430",
  "Logs": "\u0416\u0443\u0440\u043d\u0430\u043b\u044b",
  "Commands": "\u041a\u043e\u043c\u0430\u043d\u0434\u044b",
  "Presets": "\u041f\u0440\u0435\u0434\u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0438",
  "Disabling some physics": "\u041e\u0442\u043a\u043b\u044e\u0447\u0435\u043d\u0438\u0435 \u0447\u0430\u0441\u0442\u0438 \u0444\u0438\u0437\u0438\u043a\u0438",
  "Disable hair physics when there's a wig": "\u041e\u0442\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u0432\u043e\u043b\u043e\u0441 \u043f\u043e\u0434 \u043f\u0430\u0440\u0438\u043a\u043e\u043c",
  "Skip hair physics when an armor occupies the hair/longhair slot (a wig on top of the hair).": "\u041f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u0432\u043e\u043b\u043e\u0441, \u043a\u043e\u0433\u0434\u0430 \u0431\u0440\u043e\u043d\u044f \u0437\u0430\u043d\u0438\u043c\u0430\u0435\u0442 \u0441\u043b\u043e\u0442 \u0432\u043e\u043b\u043e\u0441/\u0434\u043b\u0438\u043d\u043d\u044b\u0445 \u0432\u043e\u043b\u043e\u0441 (\u043f\u0430\u0440\u0438\u043a \u043f\u043e\u0432\u0435\u0440\u0445 \u0432\u043e\u043b\u043e\u0441).",
  "No physics for your character in 1st person view": "\u0411\u0435\u0437 \u0444\u0438\u0437\u0438\u043a\u0438 \u0434\u043b\u044f \u0432\u0430\u0448\u0435\u0433\u043e \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0430 \u043e\u0442 \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u043b\u0438\u0446\u0430",
  "Skip the player's physics while in first-person view to save performance.": "\u041f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u0438\u0433\u0440\u043e\u043a\u0430 \u043e\u0442 \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u043b\u0438\u0446\u0430 \u0434\u043b\u044f \u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0438 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438.",
  "Enable NPC face parts physics": "\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u0447\u0430\u0441\u0442\u0435\u0439 \u043b\u0438\u0446\u0430 NPC",
  "Calculate physics for NPC face parts.": "\u0412\u044b\u0447\u0438\u0441\u043b\u044f\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u0447\u0430\u0441\u0442\u0435\u0439 \u043b\u0438\u0446\u0430 NPC.",
  "Distance / screen-size culling": "\u041e\u0442\u0441\u0435\u0447\u0435\u043d\u0438\u0435 \u043f\u043e \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u044e / \u0440\u0430\u0437\u043c\u0435\u0440\u0443 \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435",
  "Always-on distance": "\u0420\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e\u0439 \u0430\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0438",
  "Physics is always calculated for NPCs closer than this (units), even off-screen.": "\u0424\u0438\u0437\u0438\u043a\u0430 \u0432\u0441\u0435\u0433\u0434\u0430 \u0432\u044b\u0447\u0438\u0441\u043b\u044f\u0435\u0442\u0441\u044f \u0434\u043b\u044f NPC \u0431\u043b\u0438\u0436\u0435 \u044d\u0442\u043e\u0433\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f (\u0435\u0434\u0438\u043d\u0438\u0446), \u0434\u0430\u0436\u0435 \u0432\u043d\u0435 \u044d\u043a\u0440\u0430\u043d\u0430.",
  "Min screen size %": "\u041c\u0438\u043d. \u0440\u0430\u0437\u043c\u0435\u0440 \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 %",
  "Skip non-player NPCs smaller than this % of screen height. 0 disables the check.": "\u041f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0442\u044c NPC \u043d\u0435-\u0438\u0433\u0440\u043e\u043a\u043e\u0432 \u043c\u0435\u043d\u044c\u0448\u0435 \u044d\u0442\u043e\u0433\u043e % \u0432\u044b\u0441\u043e\u0442\u044b \u044d\u043a\u0440\u0430\u043d\u0430. 0 \u043e\u0442\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0443.",
  "Skip dead actors": "\u041f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0442\u044c \u043c\u0451\u0440\u0442\u0432\u044b\u0445 \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0435\u0439",
  "Skip physics for dead non-player actors (corpses). The player is never affected.": "\u041f\u0440\u043e\u043f\u0443\u0441\u043a\u0430\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u043c\u0451\u0440\u0442\u0432\u044b\u0445 \u043d\u0435-\u0438\u0433\u0440\u043e\u0432\u044b\u0445 \u043f\u0435\u0440\u0441\u043e\u043d\u0430\u0436\u0435\u0439 (\u0442\u0440\u0443\u043f\u043e\u0432). \u0418\u0433\u0440\u043e\u043a \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0437\u0430\u0442\u0440\u0430\u0433\u0438\u0432\u0430\u0435\u0442\u0441\u044f.",
  "Limiting active physics NPCs": "\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 \u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0445 NPC \u0441 \u0444\u0438\u0437\u0438\u043a\u043e\u0439",
  "Maximum physics NPCs": "\u041c\u0430\u043a\u0441\u0438\u043c\u0443\u043c NPC \u0441 \u0444\u0438\u0437\u0438\u043a\u043e\u0439",
  "Upper bound on simultaneously simulated NPCs (including the player).": "\u0412\u0435\u0440\u0445\u043d\u0438\u0439 \u043f\u0440\u0435\u0434\u0435\u043b \u043e\u0434\u043d\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e \u0441\u0438\u043c\u0443\u043b\u0438\u0440\u0443\u0435\u043c\u044b\u0445 NPC (\u0432\u043a\u043b\u044e\u0447\u0430\u044f \u0438\u0433\u0440\u043e\u043a\u0430).",
  "Auto-adjust the max number of physics NPCs": "\u0410\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u0440\u0435\u0433\u0443\u043b\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0435 \u0447\u0438\u0441\u043b\u043e NPC \u0441 \u0444\u0438\u0437\u0438\u043a\u043e\u0439",
  "Dynamically reduce active NPCs to stay within the frame-time budget below.": "\u0414\u0438\u043d\u0430\u043c\u0438\u0447\u0435\u0441\u043a\u0438 \u0443\u043c\u0435\u043d\u044c\u0448\u0430\u0435\u0442 \u0447\u0438\u0441\u043b\u043e \u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0445 NPC, \u0447\u0442\u043e\u0431\u044b \u0443\u043b\u043e\u0436\u0438\u0442\u044c\u0441\u044f \u0432 \u0431\u044e\u0434\u0436\u0435\u0442 \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u043a\u0430\u0434\u0440\u0430 \u043d\u0438\u0436\u0435.",
  "Frame-time budget (ms)": "\u0411\u044e\u0434\u0436\u0435\u0442 \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u043a\u0430\u0434\u0440\u0430 (\u043c\u0441)",
  "How many ms/frame physics may spend before it starts dropping active NPCs.": "\u0421\u043a\u043e\u043b\u044c\u043a\u043e \u043c\u0441 \u043d\u0430 \u043a\u0430\u0434\u0440 \u0444\u0438\u0437\u0438\u043a\u0430 \u043c\u043e\u0436\u0435\u0442 \u043f\u043e\u0442\u0440\u0430\u0442\u0438\u0442\u044c, \u043f\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043c \u043d\u0430\u0447\u043d\u0451\u0442 \u0443\u0431\u0438\u0440\u0430\u0442\u044c \u0430\u043a\u0442\u0438\u0432\u043d\u044b\u0435 NPC.",
  "Adjustment speed (sample size)": "\u0421\u043a\u043e\u0440\u043e\u0441\u0442\u044c \u0440\u0435\u0433\u0443\u043b\u0438\u0440\u043e\u0432\u043a\u0438 (\u0440\u0430\u0437\u043c\u0435\u0440 \u0432\u044b\u0431\u043e\u0440\u043a\u0438)",
  "How many samples to average for the auto-adjuster. Higher = smoother but slower to react.": "\u0421\u043a\u043e\u043b\u044c\u043a\u043e \u043e\u0431\u0440\u0430\u0437\u0446\u043e\u0432 \u0443\u0441\u0440\u0435\u0434\u043d\u044f\u0442\u044c \u0434\u043b\u044f \u0430\u0432\u0442\u043e\u0440\u0435\u0433\u0443\u043b\u0438\u0440\u043e\u0432\u043a\u0438. \u0411\u043e\u043b\u044c\u0448\u0435 = \u043f\u043b\u0430\u0432\u043d\u0435\u0435, \u043d\u043e \u043c\u0435\u0434\u043b\u0435\u043d\u043d\u0435\u0435 \u0440\u0435\u0430\u043a\u0446\u0438\u044f.",
  "Simulation quality": "\u041a\u0430\u0447\u0435\u0441\u0442\u0432\u043e \u0441\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u0438",
  "Solver iterations": "\u0418\u0442\u0435\u0440\u0430\u0446\u0438\u0438 \u0440\u0435\u0448\u0430\u0442\u0435\u043b\u044f",
  "The physics engine's solver iterations. Higher = more accurate, more CPU.": "\u0418\u0442\u0435\u0440\u0430\u0446\u0438\u0438 \u0440\u0435\u0448\u0430\u0442\u0435\u043b\u044f \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0434\u0432\u0438\u0436\u043a\u0430. \u0411\u043e\u043b\u044c\u0448\u0435 = \u0442\u043e\u0447\u043d\u0435\u0435, \u0431\u043e\u043b\u044c\u0448\u0435 \u043d\u0430\u0433\u0440\u0443\u0437\u043a\u0438 \u043d\u0430 \u0426\u041f.",
  "ERP": "ERP",
  "Error-reduction force pulling constraints back into place each step.": "\u0421\u0438\u043b\u0430 \u043a\u043e\u0440\u0440\u0435\u043a\u0446\u0438\u0438 \u043e\u0448\u0438\u0431\u043e\u043a, \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u044e\u0449\u0430\u044f \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f \u043d\u0430 \u043c\u0435\u0441\u0442\u043e \u043d\u0430 \u043a\u0430\u0436\u0434\u043e\u043c \u0448\u0430\u0433\u0435.",
  "Simulation frequency": "\u0427\u0430\u0441\u0442\u043e\u0442\u0430 \u0441\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u0438",
  "Use real time": "\u0418\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0435 \u0432\u0440\u0435\u043c\u044f",
  "Drive physics from the real-world clock instead of the in-game clock (better under slow-time).": "\u0423\u043f\u0440\u0430\u0432\u043b\u044f\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u043e\u0439 \u043f\u043e \u0447\u0430\u0441\u0430\u043c \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u043c\u0438\u0440\u0430 \u0432\u043c\u0435\u0441\u0442\u043e \u0438\u0433\u0440\u043e\u0432\u044b\u0445 (\u043b\u0443\u0447\u0448\u0435 \u043f\u0440\u0438 \u0437\u0430\u043c\u0435\u0434\u043b\u0435\u043d\u0438\u0438 \u0432\u0440\u0435\u043c\u0435\u043d\u0438).",
  "Simulation frequency (min-fps)": "\u0427\u0430\u0441\u0442\u043e\u0442\u0430 \u0441\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u0438 (min-fps)",
  "Physics steps per second. Never set below 60 or the physics engine misbehaves. Higher = smoother, more CPU.": "\u0428\u0430\u0433\u043e\u0432 \u0444\u0438\u0437\u0438\u043a\u0438 \u0432 \u0441\u0435\u043a\u0443\u043d\u0434\u0443. \u041d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u043d\u0438\u0436\u0435 60, \u0438\u043d\u0430\u0447\u0435 \u0434\u0432\u0438\u0436\u043e\u043a \u0444\u0438\u0437\u0438\u043a\u0438 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043d\u0435\u043a\u043e\u0440\u0440\u0435\u043a\u0442\u043d\u043e. \u0411\u043e\u043b\u044c\u0448\u0435 = \u043f\u043b\u0430\u0432\u043d\u0435\u0435, \u0431\u043e\u043b\u044c\u0448\u0435 \u0426\u041f.",
  "Max sub-steps": "\u041c\u0430\u043a\u0441. \u043f\u043e\u0434\u0448\u0430\u0433\u043e\u0432",
  "Max physics steps per frame. Slowdowns occur below (min-fps / maxSubSteps) fps.": "\u041c\u0430\u043a\u0441\u0438\u043c\u0443\u043c \u0448\u0430\u0433\u043e\u0432 \u0444\u0438\u0437\u0438\u043a\u0438 \u043d\u0430 \u043a\u0430\u0434\u0440. \u0417\u0430\u043c\u0435\u0434\u043b\u0435\u043d\u0438\u044f \u0432\u043e\u0437\u043d\u0438\u043a\u0430\u044e\u0442 \u043d\u0438\u0436\u0435 (min-fps / maxSubSteps) \u043a\u0430\u0434\u0440\u043e\u0432/\u0441.",
  "Rotation limits": "\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u044f \u0432\u0440\u0430\u0449\u0435\u043d\u0438\u044f",
  "Limit rotation speed": "\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0438\u0442\u044c \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u044c \u0432\u0440\u0430\u0449\u0435\u043d\u0438\u044f",
  "Rotate the player slowly through large turns instead of instantly (prevents physics explosions).": "\u041f\u043e\u0432\u043e\u0440\u0430\u0447\u0438\u0432\u0430\u0442\u044c \u0438\u0433\u0440\u043e\u043a\u0430 \u043c\u0435\u0434\u043b\u0435\u043d\u043d\u043e \u043f\u0440\u0438 \u0431\u043e\u043b\u044c\u0448\u0438\u0445 \u043f\u043e\u0432\u043e\u0440\u043e\u0442\u0430\u0445 \u0432\u043c\u0435\u0441\u0442\u043e \u043c\u0433\u043d\u043e\u0432\u0435\u043d\u043d\u043e\u0433\u043e (\u043f\u0440\u0435\u0434\u043e\u0442\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u0432\u0437\u0440\u044b\u0432\u044b \u0444\u0438\u0437\u0438\u043a\u0438).",
  "Rotation speed limit (rad/s)": "\u041f\u0440\u0435\u0434\u0435\u043b \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u0438 \u0432\u0440\u0430\u0449\u0435\u043d\u0438\u044f (\u0440\u0430\u0434/\u0441)",
  "Maximum rotation speed in radians per second when limiting is on.": "\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0430\u044f \u0441\u043a\u043e\u0440\u043e\u0441\u0442\u044c \u0432\u0440\u0430\u0449\u0435\u043d\u0438\u044f \u0432 \u0440\u0430\u0434\u0438\u0430\u043d\u0430\u0445 \u0432 \u0441\u0435\u043a\u0443\u043d\u0434\u0443, \u043a\u043e\u0433\u0434\u0430 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u0438\u0435 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043e.",
  "Reset physics on big unlimited turns": "\u0421\u0431\u0440\u0430\u0441\u044b\u0432\u0430\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u043f\u0440\u0438 \u0431\u043e\u043b\u044c\u0448\u0438\u0445 \u043d\u0435\u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043d\u044b\u0445 \u043f\u043e\u0432\u043e\u0440\u043e\u0442\u0430\u0445",
  "When rotation isn't limited, reset physics on a large turn instead of simulating the whole sweep.": "\u041a\u043e\u0433\u0434\u0430 \u0432\u0440\u0430\u0449\u0435\u043d\u0438\u0435 \u043d\u0435 \u043e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043e, \u0441\u0431\u0440\u0430\u0441\u044b\u0432\u0430\u0442\u044c \u0444\u0438\u0437\u0438\u043a\u0443 \u043f\u0440\u0438 \u0431\u043e\u043b\u044c\u0448\u043e\u043c \u043f\u043e\u0432\u043e\u0440\u043e\u0442\u0435 \u0432\u043c\u0435\u0441\u0442\u043e \u0441\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u0438 \u0432\u0441\u0435\u0433\u043e \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u044f.",
  "Reset angle (degrees)": "\u0423\u0433\u043e\u043b \u0441\u0431\u0440\u043e\u0441\u0430 (\u0433\u0440\u0430\u0434\u0443\u0441\u044b)",
  "Turn angle (degrees) above which the reset is triggered.": "\u0423\u0433\u043e\u043b \u043f\u043e\u0432\u043e\u0440\u043e\u0442\u0430 (\u0433\u0440\u0430\u0434\u0443\u0441\u044b), \u0432\u044b\u0448\u0435 \u043a\u043e\u0442\u043e\u0440\u043e\u0433\u043e \u0441\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0435\u0442 \u0441\u0431\u0440\u043e\u0441.",
  "Enable FSMP-native wind": "\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0432\u0435\u0442\u0435\u0440 FSMP",
  "Apply FSMP's own wind force to physics objects.": "\u041f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u0442 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0443\u044e \u0441\u0438\u043b\u0443 \u0432\u0435\u0442\u0440\u0430 FSMP \u043a \u043e\u0431\u044a\u0435\u043a\u0442\u0430\u043c \u0444\u0438\u0437\u0438\u043a\u0438.",
  "Wind strength": "\u0421\u0438\u043b\u0430 \u0432\u0435\u0442\u0440\u0430",
  "Base wind strength. For reference, gravity is 9.8.": "\u0411\u0430\u0437\u043e\u0432\u0430\u044f \u0441\u0438\u043b\u0430 \u0432\u0435\u0442\u0440\u0430. \u0414\u043b\u044f \u0441\u0440\u0430\u0432\u043d\u0435\u043d\u0438\u044f, \u0433\u0440\u0430\u0432\u0438\u0442\u0430\u0446\u0438\u044f \u0440\u0430\u0432\u043d\u0430 9.8.",
  "Distance for no wind": "\u0420\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0434\u043b\u044f \u043e\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044f \u0432\u0435\u0442\u0440\u0430",
  "How close to an obstruction for wind to be fully blocked.": "\u041d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0431\u043b\u0438\u0437\u043a\u043e \u043a \u043f\u0440\u0435\u043f\u044f\u0442\u0441\u0442\u0432\u0438\u044e \u0432\u0435\u0442\u0435\u0440 \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u0431\u043b\u043e\u043a\u0438\u0440\u0443\u0435\u0442\u0441\u044f.",
  "Distance for max wind": "\u0420\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u0434\u043b\u044f \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0435\u0442\u0440\u0430",
  "How far from an obstruction for wind to be unblocked. Scales linearly with the above.": "\u041d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0434\u0430\u043b\u0435\u043a\u043e \u043e\u0442 \u043f\u0440\u0435\u043f\u044f\u0442\u0441\u0442\u0432\u0438\u044f \u0432\u0435\u0442\u0435\u0440 \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u0451\u0442 \u0431\u043b\u043e\u043a\u0438\u0440\u043e\u0432\u0430\u0442\u044c\u0441\u044f. \u041c\u0430\u0441\u0448\u0442\u0430\u0431\u0438\u0440\u0443\u0435\u0442\u0441\u044f \u043b\u0438\u043d\u0435\u0439\u043d\u043e \u0441 \u0443\u043a\u0430\u0437\u0430\u043d\u043d\u044b\u043c \u0432\u044b\u0448\u0435.",
  "Mods folder": "\u041f\u0430\u043f\u043a\u0430 \u043c\u043e\u0434\u043e\u0432",
  "Your mod manager's mods folder (MO2 mods/ or Vortex staging). When set, 'smp report' scans it\nnatively instead of through the virtual file system, which is much faster on big load orders.\nLeave empty to scan data/ through the VFS.": "\u041f\u0430\u043f\u043a\u0430 \u043c\u043e\u0434\u043e\u0432 \u0432\u0430\u0448\u0435\u0433\u043e \u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440\u0430 (MO2 mods/ \u0438\u043b\u0438 staging Vortex). \u0415\u0441\u043b\u0438 \u0437\u0430\u0434\u0430\u043d\u0430, 'smp report' \u0441\u043a\u0430\u043d\u0438\u0440\u0443\u0435\u0442 \u0435\u0451\n\u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e, \u0430 \u043d\u0435 \u0447\u0435\u0440\u0435\u0437 \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u0443\u044e \u0444\u0430\u0439\u043b\u043e\u0432\u0443\u044e \u0441\u0438\u0441\u0442\u0435\u043c\u0443, \u0447\u0442\u043e \u043d\u0430\u043c\u043d\u043e\u0433\u043e \u0431\u044b\u0441\u0442\u0440\u0435\u0435 \u043f\u0440\u0438 \u0431\u043e\u043b\u044c\u0448\u0438\u0445 \u0441\u043f\u0438\u0441\u043a\u0430\u0445 \u043c\u043e\u0434\u043e\u0432.\n\u041e\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u043f\u0443\u0441\u0442\u044b\u043c, \u0447\u0442\u043e\u0431\u044b \u0441\u043a\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c data/ \u0447\u0435\u0440\u0435\u0437 VFS.",
  "Log level": "\u0423\u0440\u043e\u0432\u0435\u043d\u044c \u0436\u0443\u0440\u043d\u0430\u043b\u0430",
  "0 = Fatal, 1 = Error, 2 = Warning, 3 = Message, 4 = Verbose, 5 = Debug.": "0 = \u041a\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439, 1 = \u041e\u0448\u0438\u0431\u043a\u0430, 2 = \u041f\u0440\u0435\u0434\u0443\u043f\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u0435, 3 = \u0421\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435, 4 = \u041f\u043e\u0434\u0440\u043e\u0431\u043d\u044b\u0439, 5 = \u041e\u0442\u043b\u0430\u0434\u043a\u0430.",
  "Master switch": "\u0413\u043b\u0430\u0432\u043d\u044b\u0439 \u043f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0430\u0442\u0435\u043b\u044c",
  "SMP enabled": "SMP \u0432\u043a\u043b\u044e\u0447\u0451\u043d",
  "Turn the whole physics simulation on or off (same as 'smp on' / 'smp off').": "\u0412\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0438\u043b\u0438 \u0432\u044b\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0432\u0441\u044e \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0443\u044e \u0441\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u044e (\u043a\u0430\u043a 'smp on' / 'smp off').",
  "Console commands (shown below, and in the console / log)": "\u041a\u043e\u043c\u0430\u043d\u0434\u044b \u043a\u043e\u043d\u0441\u043e\u043b\u0438 (\u043f\u043e\u043a\u0430\u0437\u0430\u043d\u044b \u043d\u0438\u0436\u0435, \u0430 \u0442\u0430\u043a\u0436\u0435 \u0432 \u043a\u043e\u043d\u0441\u043e\u043b\u0438 / \u043b\u043e\u0433\u0435)",
  "smp (basic info)": "smp (\u043e\u0441\u043d\u043e\u0432\u043d\u0430\u044f \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044f)",
  "smp reset": "smp reset",
  "Reload config and reset all physics systems.": "\u041f\u0435\u0440\u0435\u0437\u0430\u0433\u0440\u0443\u0436\u0430\u0435\u0442 \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044e \u0438 \u0441\u0431\u0440\u0430\u0441\u044b\u0432\u0430\u0435\u0442 \u0432\u0441\u0435 \u0441\u0438\u0441\u0442\u0435\u043c\u044b \u0444\u0438\u0437\u0438\u043a\u0438.",
  "smp list": "smp list",
  "smp detail": "smp detail",
  "smp dumptree (player)": "smp dumptree (\u0438\u0433\u0440\u043e\u043a)",
  "Dump the player's 3D node tree to the log (needs log level 3+).": "\u0417\u0430\u043f\u0438\u0441\u044b\u0432\u0430\u0435\u0442 3D-\u0434\u0435\u0440\u0435\u0432\u043e \u0443\u0437\u043b\u043e\u0432 \u0438\u0433\u0440\u043e\u043a\u0430 \u0432 \u0436\u0443\u0440\u043d\u0430\u043b (\u043d\u0443\u0436\u0435\u043d \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u0436\u0443\u0440\u043d\u0430\u043b\u0430 3+).",
  "smp QueryOverride": "smp QueryOverride",
  "Validator": "\u0412\u0430\u043b\u0438\u0434\u0430\u0442\u043e\u0440",
  "smp report": "smp report",
  "Run the physics-asset validator in the background; writes a report file.": "\u0417\u0430\u043f\u0443\u0441\u043a\u0430\u0435\u0442 \u0432\u0430\u043b\u0438\u0434\u0430\u0442\u043e\u0440 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0440\u0435\u0441\u0443\u0440\u0441\u043e\u0432 \u0432 \u0444\u043e\u043d\u0435; \u0437\u0430\u043f\u0438\u0441\u044b\u0432\u0430\u0435\u0442 \u0444\u0430\u0439\u043b \u043e\u0442\u0447\u0451\u0442\u0430.",
  "smp report gear": "smp report gear",
  "Validate currently equipped gear only.": "\u041f\u0440\u043e\u0432\u0435\u0440\u044f\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u0442\u0435\u043a\u0443\u0449\u0443\u044e \u044d\u043a\u0438\u043f\u0438\u0440\u043e\u0432\u043a\u0443.",
  "Refresh": "\u041e\u0431\u043d\u043e\u0432\u0438\u0442\u044c",
  "(%d found)": "(\u043d\u0430\u0439\u0434\u0435\u043d\u043e: %d)",
  "No presets found in configsPresets/. Drop *.json preset files there.": "\u041f\u0440\u0435\u0434\u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043a\u0438 \u0432 configsPresets/ \u043d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d\u044b. \u041f\u043e\u043c\u0435\u0441\u0442\u0438\u0442\u0435 \u0442\u0443\u0434\u0430 \u0444\u0430\u0439\u043b\u044b \u043f\u0440\u0435\u0434\u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043e\u043a *.json.",
  "(loaded)": "(\u0437\u0430\u0433\u0440\u0443\u0436\u0435\u043d\u043e)",
  "Auto (game language)": "\u0410\u0432\u0442\u043e (\u044f\u0437\u044b\u043a \u0438\u0433\u0440\u044b)",
  "Search settings": "\u041f\u043e\u0438\u0441\u043a \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438",
  "Reset this setting to its default": "\u0421\u0431\u0440\u043e\u0441\u0438\u0442\u044c \u044d\u0442\u0443 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0443 \u043a \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044e \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e",
  "Physics is ON": "\u0424\u0438\u0437\u0438\u043a\u0430 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u0430",
  "Physics is OFF": "\u0424\u0438\u0437\u0438\u043a\u0430 \u0432\u044b\u043a\u043b\u044e\u0447\u0435\u043d\u0430",
  "Distance for no wind should be below distance for max wind.": "\u0420\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u0435 \u043e\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044f \u0432\u0435\u0442\u0440\u0430 \u0434\u043e\u043b\u0436\u043d\u043e \u0431\u044b\u0442\u044c \u043c\u0435\u043d\u044c\u0448\u0435 \u0440\u0430\u0441\u0441\u0442\u043e\u044f\u043d\u0438\u044f \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0432\u0435\u0442\u0440\u0430.",
  "The menu language. 'Auto' follows Skyrim's own language.": "\u042f\u0437\u044b\u043a \u043c\u0435\u043d\u044e. \u00ab\u0410\u0432\u0442\u043e\u00bb \u0441\u043b\u0435\u0434\u0443\u0435\u0442 \u0437\u0430 \u044f\u0437\u044b\u043a\u043e\u043c Skyrim.",
  "In-game configuration menu for Faster HDT-SMP.": "\u0412\u043d\u0443\u0442\u0440\u0438\u0438\u0433\u0440\u043e\u0432\u043e\u0435 \u043c\u0435\u043d\u044e \u043d\u0430\u0441\u0442\u0440\u043e\u0435\u043a \u0434\u043b\u044f Faster HDT-SMP.",
  "Documentation": "\u0414\u043e\u043a\u0443\u043c\u0435\u043d\u0442\u0430\u0446\u0438\u044f",
  "Nexus page": "\u0421\u0442\u0440\u0430\u043d\u0438\u0446\u0430 Nexus",
  "Report a bug": "\u0421\u043e\u043e\u0431\u0449\u0438\u0442\u044c \u043e\u0431 \u043e\u0448\u0438\u0431\u043a\u0435",
  "Open in your browser": "\u041e\u0442\u043a\u0440\u044b\u0442\u044c \u0432 \u0431\u0440\u0430\u0443\u0437\u0435\u0440\u0435",
  "Configuration": "\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438",
  "Output": "\u0412\u044b\u0432\u043e\u0434",
  "Clear": "\u041e\u0447\u0438\u0441\u0442\u0438\u0442\u044c",
  "Browse for your mods folder": "\u0412\u044b\u0431\u0440\u0430\u0442\u044c \u043f\u0430\u043f\u043a\u0443 \u043c\u043e\u0434\u043e\u0432",
  "Live physics performance data --- the same numbers written to hdtSMP64.log.": "\u0414\u0430\u043d\u043d\u044b\u0435 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0444\u0438\u0437\u0438\u043a\u0438 \u0432 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u043c \u0432\u0440\u0435\u043c\u0435\u043d\u0438 \u2014 \u0442\u0435 \u0436\u0435 \u0446\u0438\u0444\u0440\u044b, \u0447\u0442\u043e \u0438 \u0432 hdtSMP64.log.",
  "Physics simulation is off.": "\u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043a\u0430\u044f \u0441\u0438\u043c\u0443\u043b\u044f\u0446\u0438\u044f \u0432\u044b\u043a\u043b\u044e\u0447\u0435\u043d\u0430.",
  "Frame-time cost": "\u0417\u0430\u0442\u0440\u0430\u0442\u044b \u043d\u0430 \u043a\u0430\u0434\u0440",
  "Frame-time impact": "\u0412\u043b\u0438\u044f\u043d\u0438\u0435 \u043d\u0430 \u043a\u0430\u0434\u0440",
  "Setup": "\u041f\u043e\u0434\u0433\u043e\u0442\u043e\u0432\u043a\u0430",
  "Wait": "\u041e\u0436\u0438\u0434\u0430\u043d\u0438\u0435",
  "Apply": "\u041f\u0440\u0438\u043c\u0435\u043d\u0435\u043d\u0438\u0435",
  "Background calc": "\u0424\u043e\u043d\u043e\u0432\u044b\u0439 \u0440\u0430\u0441\u0447\u0451\u0442",
  "Hidden (overlapped)": "\u0421\u043a\u0440\u044b\u0442\u043e (\u043f\u0435\u0440\u0435\u043a\u0440\u044b\u0442\u043e)",
  "Total CPU work": "\u0412\u0441\u0435\u0433\u043e \u0440\u0430\u0431\u043e\u0442\u044b \u0426\u041f",
  "Load": "\u041d\u0430\u0433\u0440\u0443\u0437\u043a\u0430",
  "Active physics NPCs": "\u0410\u043a\u0442\u0438\u0432\u043d\u044b\u0435 NPC \u0441 \u0444\u0438\u0437\u0438\u043a\u043e\u0439",
  "Show overlay while playing": "\u041f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u043e\u0432\u0435\u0440\u043b\u0435\u0439 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0438\u0433\u0440\u044b",
  "Show a small always-on-top readout of the frame-time cost while you play.": "\u041f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u0442 \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u043e\u0439 \u0438\u043d\u0434\u0438\u043a\u0430\u0442\u043e\u0440 \u0437\u0430\u0442\u0440\u0430\u0442 \u043d\u0430 \u043a\u0430\u0434\u0440 \u043f\u043e\u0432\u0435\u0440\u0445 \u043e\u043a\u043e\u043d \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0438\u0433\u0440\u044b.",
  "Gear only": "\u0422\u043e\u043b\u044c\u043a\u043e \u044d\u043a\u0438\u043f\u0438\u0440\u043e\u0432\u043a\u0430",
  "Include warnings": "\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u043f\u0440\u0435\u0434\u0443\u043f\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f",
  "Include warnings and info in the report (otherwise errors only).": "\u0412\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u043f\u0440\u0435\u0434\u0443\u043f\u0440\u0435\u0436\u0434\u0435\u043d\u0438\u044f \u0438 \u0438\u043d\u0444\u043e\u0440\u043c\u0430\u0446\u0438\u044e \u0432 \u043e\u0442\u0447\u0451\u0442 (\u0438\u043d\u0430\u0447\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u043e\u0448\u0438\u0431\u043a\u0438).",
  "Run report": "\u0417\u0430\u043f\u0443\u0441\u0442\u0438\u0442\u044c \u043e\u0442\u0447\u0451\u0442",
  "Profiler": "\u041f\u0440\u043e\u0444\u0438\u043b\u0438\u0440\u043e\u0432\u0449\u0438\u043a",
  "Sample frames": "\u041a\u0430\u0434\u0440\u044b \u0432\u044b\u0431\u043e\u0440\u043a\u0438",
  "Print every N frames": "\u0412\u044b\u0432\u043e\u0434\u0438\u0442\u044c \u043a\u0430\u0436\u0434\u044b\u0435 N \u043a\u0430\u0434\u0440\u043e\u0432",
  "Toggle physics profiler": "\u041f\u0435\u0440\u0435\u043a\u043b\u044e\u0447\u0438\u0442\u044c \u043f\u0440\u043e\u0444\u0438\u043b\u0438\u0440\u043e\u0432\u0449\u0438\u043a \u0444\u0438\u0437\u0438\u043a\u0438",
  "Toggle physics profiler capture on/off; results are written to hdtSMP64.log.": "\u0412\u043a\u043b\u044e\u0447\u0430\u0435\u0442/\u0432\u044b\u043a\u043b\u044e\u0447\u0430\u0435\u0442 \u0437\u0430\u0445\u0432\u0430\u0442 \u043f\u0440\u043e\u0444\u0438\u043b\u0438\u0440\u043e\u0432\u0449\u0438\u043a\u0430 \u0444\u0438\u0437\u0438\u043a\u0438; \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442\u044b \u0437\u0430\u043f\u0438\u0441\u044b\u0432\u0430\u044e\u0442\u0441\u044f \u0432 hdtSMP64.log.",
  "Log file": "\u0424\u0430\u0439\u043b \u0436\u0443\u0440\u043d\u0430\u043b\u0430",
  "Auto-refresh": "\u0410\u0432\u0442\u043e\u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435",
  "(last %d KB)": "(\u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0435 %d \u041a\u0411)",
  "Increase font size": "\u0423\u0432\u0435\u043b\u0438\u0447\u0438\u0442\u044c \u0440\u0430\u0437\u043c\u0435\u0440 \u0448\u0440\u0438\u0444\u0442\u0430",
  "Decrease font size": "\u0423\u043c\u0435\u043d\u044c\u0448\u0438\u0442\u044c \u0440\u0430\u0437\u043c\u0435\u0440 \u0448\u0440\u0438\u0444\u0442\u0430",
  "Measures": "\u0418\u0437\u043c\u0435\u0440\u0435\u043d\u0438\u044f",
  "Home": "\u0413\u043b\u0430\u0432\u043d\u0430\u044f",
  "The page names on the left switch language after a game restart.": "\u041d\u0430\u0437\u0432\u0430\u043d\u0438\u044f \u0441\u0442\u0440\u0430\u043d\u0438\u0446 \u0441\u043b\u0435\u0432\u0430 \u0441\u043c\u0435\u043d\u044f\u0442 \u044f\u0437\u044b\u043a \u043f\u043e\u0441\u043b\u0435 \u043f\u0435\u0440\u0435\u0437\u0430\u043f\u0443\u0441\u043a\u0430 \u0438\u0433\u0440\u044b.",
  "Bundle a bug report": "\u0421\u043e\u0431\u0440\u0430\u0442\u044c \u043e\u0442\u0447\u0451\u0442 \u043e\u0431 \u043e\u0448\u0438\u0431\u043a\u0435",
  "Current hdtSMP64.log": "\u0422\u0435\u043a\u0443\u0449\u0438\u0439 hdtSMP64.log",
  "Last validation report": "\u041f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439 \u043e\u0442\u0447\u0451\u0442 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0438",
  "Adds a fresh 'smp report gear' report to the zip. This takes a few seconds.": "\u0414\u043e\u0431\u0430\u0432\u043b\u044f\u0435\u0442 \u0432 \u0430\u0440\u0445\u0438\u0432 \u0441\u0432\u0435\u0436\u0438\u0439 \u043e\u0442\u0447\u0451\u0442 'smp report gear'. \u042d\u0442\u043e \u0437\u0430\u043d\u0438\u043c\u0430\u0435\u0442 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0441\u0435\u043a\u0443\u043d\u0434.",
  "Last crash log": "\u041f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u0439 \u043a\u0440\u0430\u0448-\u043b\u043e\u0433",
  "Adds the most recent CrashLogger crash log, if any.": "\u0414\u043e\u0431\u0430\u0432\u043b\u044f\u0435\u0442 \u0441\u0430\u043c\u044b\u0439 \u0441\u0432\u0435\u0436\u0438\u0439 \u043a\u0440\u0430\u0448-\u043b\u043e\u0433 CrashLogger, \u0435\u0441\u043b\u0438 \u043e\u043d \u0435\u0441\u0442\u044c.",
  "Build report zip": "\u0421\u043e\u0437\u0434\u0430\u0442\u044c zip",
  "Open logs folder": "\u041e\u0442\u043a\u0440\u044b\u0442\u044c \u043f\u0430\u043f\u043a\u0443 \u0436\u0443\u0440\u043d\u0430\u043b\u043e\u0432",
  "Building the report zip...": "\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 zip...",
  "Report zip saved:": "Zip \u0441\u043e\u0445\u0440\u0430\u043d\u0451\u043d:",
  "Could not build the report zip.": "\u041d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c \u0441\u043e\u0437\u0434\u0430\u0442\u044c zip."
}
